import pandas as pd 
df['Popularity'] = pd.to_numeric(df['Popularity'],errors='coerce')

#find top 5 artist based on average popularity
top5_artist = df.groupby('Artist')['Popularity'].mean().sort_values(ascending=False).head(5).index

#Filter dataset for those artists
top_artist_data = df[df['Artist'].isin(top5_artist)]

#get most popular track for each artist
most_popular_tracks = (top_artist_data.sort_values('Popularity',ascending=False).groupby('Artist').first()['Track Name','Popularity'])
print("Most Popularity Track for Each of top 5 Artist:")
print(most_popular_tracks)
